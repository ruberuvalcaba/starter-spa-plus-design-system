{
  "name": "@acme/ui",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
    "./tokens": { "types": "./dist/tokens/index.d.ts", "import": "./dist/tokens/index.js" }
  },
  "files": ["dist"],
  "sideEffects": ["*.css"],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
